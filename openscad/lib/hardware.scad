include <../00_parametros.scad>;

//----------------------------------------------------------
// PCB UM790
//----------------------------------------------------------

module um790PCB()
{
    color([0.0,0.45,0.10])

        cube([
            pcb_x,
            pcb_y,
            pcb_thickness
        ]);
}

//----------------------------------------------------------
// Disipador
//----------------------------------------------------------

module um790Cooler()
{

    color("gray")

    translate([
        (pcb_x-um790_cooler_x)/2,
        (pcb_y-um790_cooler_y)/2,
        pcb_thickness
    ])

    cube([
        um790_cooler_x,
        um790_cooler_y,
        um790_cooler_h
    ]);

}

//----------------------------------------------------------
// Volumen conectores traseros
//----------------------------------------------------------

module um790RearIO()
{

    color("silver")

    translate([
        0,
        pcb_y-2,
        0
    ])

    cube([
        pcb_x,
        2,
        22
    ]);

}

//----------------------------------------------------------
// Conjunto UM790
//----------------------------------------------------------

module um790()
{

    um790PCB();

    um790Cooler();

    um790RearIO();

}

