include <../00_parametros.scad>;

$fn=32;

//--------------------------------------------------
// PCB UM790
//--------------------------------------------------

module um790PCB()
{
    color([0.0,0.45,0.10])

        cube([
            pcb_x,
            pcb_y,
            pcb_thickness
        ]);
}

//--------------------------------------------------
// Disipador UM790
//--------------------------------------------------

module um790Cooler()
{

    color("gray")

    translate([
        pcb_x/2-40,
        pcb_y/2-40,
        pcb_thickness
    ])

    cube([
        80,
        80,
        15
    ]);

}

//--------------------------------------------------
// Volumen conectores traseros
//--------------------------------------------------

module um790RearIO()
{

    color("silver")

    translate([
        0,
        pcb_y-2,
        0
    ])

    cube([
        pcb_x,
        2,
        22
    ]);

}

//--------------------------------------------------
// Modelo completo UM790
//--------------------------------------------------

module um790()
{

    um790PCB();

    um790Cooler();

    um790RearIO();

}

